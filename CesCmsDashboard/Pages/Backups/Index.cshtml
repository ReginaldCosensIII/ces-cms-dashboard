@page
@model CesCmsDashboard.Pages.Backups.IndexModel
@{
    ViewData["Title"] = "Database Backups";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="mb-0 fw-bold text-semantic-sidebar">Database Backups</h2>
    <button class="btn btn-primary d-flex align-items-center gap-2">
        <i data-lucide="database-backup" class="icon-sm"></i> Generate Database Backup
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Backup Name</th>
                        <th>Created Date</th>
                        <th>Size</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    <tr>
                        <td class="ps-4 fw-medium text-truncate max-w-300">
                            <i data-lucide="file-archive" class="icon-sm me-2 text-muted"></i>
                            ces_prod_backup_20260410.bak
                        </td>
                        <td>Apr 10, 2026, 03:00 AM</td>
                        <td>420 MB</td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1">
                                <i data-lucide="download" class="icon-sm"></i> Download
                            </button>
                            <button class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-1 ms-1">
                                <i data-lucide="trash-2" class="icon-sm"></i> Delete
                            </button>
                        </td>
                    </tr>
                    <tr>
                        <td class="ps-4 fw-medium text-truncate max-w-300">
                            <i data-lucide="file-archive" class="icon-sm me-2 text-muted"></i>
                            ces_prod_backup_20260403.bak
                        </td>
                        <td>Apr 03, 2026, 03:00 AM</td>
                        <td>415 MB</td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1">
                                <i data-lucide="download" class="icon-sm"></i> Download
                            </button>
                            <button class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-1 ms-1">
                                <i data-lucide="trash-2" class="icon-sm"></i> Delete
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
