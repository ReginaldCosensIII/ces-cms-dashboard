@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard Home";
}

<!-- Page Header -->
<div class="page-header">
    <h1 class="mb-0">Dashboard</h1>
    <p class="page-subtitle mb-0">Live intelligence for your content pipeline.</p>
</div>

<!-- ── Top Stat Cards (3-column) ─────────────────────────── -->
<div class="row g-3 mb-4">

    <!-- Card 1: Published Content -->
    <div class="col-md-6 col-xl-4">
        <div class="stat-card">
            <div class="stat-card-icon icon-green">
                <i data-lucide="circle-check-big" class="icon-lg" style="color:#1a6644;"></i>
            </div>
            <div class="stat-card-body">
                <div class="stat-value">@(Model.PublishedFaqs + Model.PublishedTechTips)</div>
                <div class="stat-label">Published</div>
                <div class="stat-metric-row">
                    <span class="stat-metric-pill pill-green">
                        <i data-lucide="message-square-more" style="width:10px;height:10px;"></i>
                        @Model.PublishedFaqs FAQs
                    </span>
                    <span class="stat-metric-pill pill-slate">
                        <i data-lucide="lightbulb" style="width:10px;height:10px;"></i>
                        @Model.PublishedTechTips Tips
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 2: Drafts Pending -->
    <div class="col-md-6 col-xl-4">
        <div class="stat-card">
            <div class="stat-card-icon icon-amber">
                <i data-lucide="file-pen-line" class="icon-lg" style="color:#92400e;"></i>
            </div>
            <div class="stat-card-body">
                <div class="stat-value">@(Model.DraftFaqs + Model.DraftTechTips)</div>
                <div class="stat-label">Drafts Pending</div>
                <div class="stat-metric-row">
                    <span class="stat-metric-pill pill-amber">
                        <i data-lucide="message-square-more" style="width:10px;height:10px;"></i>
                        @Model.DraftFaqs FAQs
                    </span>
                    <span class="stat-metric-pill pill-amber">
                        <i data-lucide="lightbulb" style="width:10px;height:10px;"></i>
                        @Model.DraftTechTips Tips
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 3: System Health — full-width dedicated component -->
    <div class="col-md-12 col-xl-4">
        <div class="health-card">
            <div class="health-card-header">
                <div class="health-card-icon">
                    <i data-lucide="shield-check"></i>
                </div>
                <span class="health-card-title">System Health</span>
            </div>
            <ul class="health-row-list">
                <li class="health-row">
                    <span class="health-row-label">
                        <span class="health-service-icon svc-db">
                            <i data-lucide="database"></i>
                        </span>
                        Database
                    </span>
                    @if (Model.IsDatabaseConnected)
                    {
                        <span class="health-badge badge-online">Online</span>
                    }
                    else
                    {
                        <span class="health-badge badge-offline">Offline</span>
                    }
                </li>
                <li class="health-row">
                    <span class="health-row-label">
                        <span class="health-service-icon svc-ai">
                            <i data-lucide="sparkles"></i>
                        </span>
                        AI Co-Pilot
                    </span>
                    @if (Model.IsAiApiConfigured)
                    {
                        <span class="health-badge badge-online">Connected</span>
                    }
                    else
                    {
                        <span class="health-badge badge-pending">Pending Setup</span>
                    }
                </li>
                <li class="health-row">
                    <span class="health-row-label">
                        <span class="health-service-icon svc-web">
                            <i data-lucide="globe"></i>
                        </span>
                        Public Website
                    </span>
                    <span class="health-badge badge-pending">Ping: Pending</span>
                </li>
                <li class="health-row">
                    <span class="health-row-label">
                        <span class="health-service-icon svc-seo">
                            <i data-lucide="search"></i>
                        </span>
                        SEO Injectors
                    </span>
                    <span class="health-badge badge-online">Active</span>
                </li>
            </ul>
        </div>
    </div>

</div>

<!-- ── Detail Cards Row ───────────────────────────────────── -->
<div class="row g-4">

    <!-- Left: Recent Activity (Database-wired) -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2 px-4 py-3">
                <div class="stat-card-icon icon-maroon" style="width:36px;height:36px;border-radius:10px;flex-shrink:0;">
                    <i data-lucide="list-checks" class="icon-md" style="color:var(--color-maroon);"></i>
                </div>
                <h5 class="card-title fw-bold mb-0 activity-card-title">Recent Activity</h5>
                @if (Model.RecentActivities.Any())
                {
                    <span class="ms-auto stat-metric-pill pill-slate">@Model.RecentActivities.Count items</span>
                }
            </div>
            <div class="card-body px-4 py-2">

                @if (!Model.RecentActivities.Any())
                {
                    <div class="d-flex align-items-center justify-content-center py-5 text-muted">
                        <i data-lucide="inbox" class="me-2 icon-md"></i>
                        <span>No recent activity yet.</span>
                    </div>
                }
                else
                {
                    <ul class="list-unstyled mb-0 activity-list">
                        @foreach (var activity in Model.RecentActivities)
                        {
                            var iconName  = activity.Type == "FAQ" ? "message-square-more" : "lightbulb";
                            var iconClass = activity.Type == "FAQ" ? "activity-icon-save"   : "activity-icon-plus";
                            var badgeClass = activity.Type == "FAQ" ? "badge-faq" : "badge-techtip";
                            var statusClass = activity.Status == "Published" ? "status-published" : "status-draft";
                            var dateLabel = activity.Date.ToString("MMM dd, yyyy h:mm tt");

                            <li class="activity-item">
                                <div class="activity-icon-wrap @iconClass">
                                    <i data-lucide="@iconName"></i>
                                </div>
                                <div class="activity-text">
                                    <span class="activity-action" title="@activity.Title">@activity.Title</span>
                                    <span class="activity-time d-flex align-items-center gap-1 flex-wrap">
                                        <span class="activity-badge @badgeClass">@activity.Type</span>
                                        <span class="activity-status @statusClass">@activity.Status</span>
                                        <span>@dateLabel</span>
                                    </span>
                                </div>
                            </li>
                        }
                    </ul>
                }

            </div>
        </div>
    </div>

    <!-- Right: CES SEO Copilot -->
    <div class="col-lg-6">
        <div class="card h-100 d-flex flex-column">
            <div class="card-header d-flex align-items-center gap-2 px-4 py-3 copilot-header">
                <div class="stat-card-icon copilot-icon" style="width:36px;height:36px;border-radius:10px;flex-shrink:0;">
                    <i data-lucide="sparkles" class="icon-md" style="color:var(--color-light-green);"></i>
                </div>
                <h5 class="card-title fw-bold mb-0 text-white" style="font-size:0.95rem;">CES SEO Copilot</h5>
                <span class="ms-auto copilot-beta-badge">BETA</span>
            </div>
            <div class="card-body d-flex flex-column px-4 pt-4">

                <!-- Chat history area -->
                <div class="copilot-chat-area flex-grow-1 p-3 mb-3">
                    <div class="d-flex mb-3">
                        <div class="chat-bubble">
                            <strong class="copilot-label">Copilot</strong><br>
                            Welcome to the SEO Copilot. How can I assist you with your content today?
                        </div>
                    </div>
                </div>

                <!-- Input area -->
                <div class="input-group mt-auto">
                    <input type="text" class="form-control copilot-input"
                           placeholder="Ask Copilot a question..."
                           aria-label="Ask the SEO Copilot a question"
                           id="copilot-input">
                    <button class="btn copilot-send-btn d-flex align-items-center gap-2 px-3"
                            id="copilot-send-btn"
                            type="button">
                        <i data-lucide="send" class="icon-sm"></i>
                        <span class="d-none d-sm-inline">Send</span>
                    </button>
                </div>

            </div>
        </div>
    </div>

</div>
