@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard Home";
}

<!-- Page Header -->
<div class="page-header">
    <h1 class="mb-0">Dashboard</h1>
    <p class="page-subtitle mb-0">Welcome back. Here's an overview of your system.</p>
</div>

<!-- Stat Cards Row -->
<div class="row g-3 mb-4 position-relative z-3">

    <!-- Total Content -->
    <div class="col-sm-6 col-xl-4">
        <div class="stat-card">
            <div class="stat-card-icon" style="background-color:rgba(128, 0, 0, 0.1);">
                <i data-lucide="files" class="icon-lg" style="color:#800000;"></i>
            </div>
            <div class="stat-card-body">
                <div class="stat-value">@Model.TotalFaqs</div>
                <div class="stat-label">Total FAQs</div>
                <div class="stat-sub">Frequently Asked Questions</div>
            </div>
        </div>
    </div>

    <!-- Published -->
    <div class="col-sm-6 col-xl-4">
        <div class="stat-card">
            <div class="stat-card-icon icon-green">
                <i data-lucide="circle-check-big" class="icon-lg" style="color:#1a6644;"></i>
            </div>
            <div class="stat-card-body">
                <div class="stat-value">@Model.TotalTechTips</div>
                <div class="stat-label">Total Tech Tips</div>
                <div class="stat-sub text-success fw-medium">Technical Guides</div>
            </div>
        </div>
    </div>

    <!-- System Status -->
    <div class="col-sm-12 col-xl-4">
        <div class="stat-card position-relative">
            @if (Model.IsDatabaseConnected)
            {
                <div class="stat-card-icon icon-green">
                    <i data-lucide="activity" class="icon-lg" style="color:#1a6644;"></i>
                </div>
                <div class="stat-card-body">
                    <div class="stat-value text-dark">Online</div>
                    <div class="stat-label">System Status</div>
                    <div class="stat-sub fw-medium" style="color:#1a6644;">Online & Connected</div>
                </div>
            }
            else
            {
                <div class="stat-card-icon" style="background-color:rgba(255, 0, 0, 0.1);">
                    <i data-lucide="activity" class="icon-lg" style="color:red;"></i>
                </div>
                <div class="stat-card-body">
                    <div class="stat-value" style="color:red;">Offline</div>
                    <div class="stat-label">System Status</div>
                    <div class="stat-sub text-danger fw-medium">Database Error</div>
                </div>
            }
            <div class="dropdown position-absolute bottom-0 end-0 m-2">
                <a href="#" class="text-muted text-decoration-none px-2" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 1.2rem;">
                    <i class="bi bi-plus-circle"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-3" style="min-width: 200px; font-size: 0.85rem; z-index: 1050;">
                    <li class="d-flex justify-content-between mb-2 text-muted"><strong>Database:</strong> <span class="ms-3">@(Model.IsDatabaseConnected ? "Connected" : "Error")</span></li>
                    <li class="d-flex justify-content-between mb-2 text-muted"><strong>AI Copilot:</strong> <span class="ms-3">@(Model.IsAiApiConfigured ? "Ready" : "Pending")</span></li>
                    <li class="d-flex justify-content-between mb-2 text-muted"><strong>Web Ping:</strong> <span class="ms-3">OK</span></li>
                    <li class="d-flex justify-content-between text-muted"><strong>SEO Injector:</strong> <span class="ms-3">Active</span></li>
                </ul>
            </div>
        </div>
    </div>

</div>

<!-- Detail Cards Row -->
<div class="row g-4">

    <!-- Left: Recent Activity (Database-wired) -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2 px-4 py-3">
                <div class="stat-card-icon" style="width:34px;height:34px;border-radius:8px;background:rgba(133,204,170,0.2);">
                    <i data-lucide="list-checks" class="icon-md" style="color:#1a6644;"></i>
                </div>
                <h5 class="card-title fw-bold mb-0 activity-card-title">Recent Activity</h5>
            </div>
            <div class="card-body px-4 py-2">

                @if (!Model.RecentActivities.Any())
                {
                    <div class="d-flex align-items-center justify-content-center py-5 text-muted">
                        <i data-lucide="inbox" class="me-2 icon-md"></i>
                        <span style="font-size:0.875rem;">No recent activity yet.</span>
                    </div>
                }
                else
                {
                    <ul class="list-unstyled mb-0 activity-list">
                        @foreach (var activity in Model.RecentActivities)
                        {
                            <!-- Determine icon + color class by content type -->
                            var iconName  = activity.Type == "FAQ" ? "message-square-more" : "lightbulb";
                            var iconClass = activity.Type == "FAQ" ? "activity-icon-edit"  : "activity-icon-plus";
                            var typeLabel = activity.Type;
                            var statusLabel = activity.Status;
                            var dateLabel = activity.Date.ToString("MMM dd, yyyy h:mm tt");

                            <li class="activity-item">
                                <div class="activity-icon-wrap @iconClass" style="background:@(activity.Type == "FAQ" ? "rgba(128,0,0,0.1)" : "rgba(133,204,170,0.25)");">
                                    <i data-lucide="@iconName" class="icon-sm" style="color:@(activity.Type == "FAQ" ? "#800000" : "#1a6644");"></i>
                                </div>
                                <div class="activity-text">
                                    <span class="activity-action" title="@activity.Title">@activity.Title - @statusLabel</span>
                                    <span class="activity-time">
                                        <span class="badge rounded-pill px-2 py-1 me-1"
                                              style="font-size:0.65rem;background:@(activity.Type == "FAQ" ? "rgba(128,0,0,0.1)" : "rgba(133,204,170,0.25)");color:@(activity.Type == "FAQ" ? "#800000" : "#1a6644");">
                                            @typeLabel
                                        </span>
                                        @dateLabel
                                    </span>
                                </div>
                            </li>
                        }
                    </ul>
                }

            </div>
        </div>
    </div>

    <!-- Right: CES SEO Copilot -->
    <div class="col-lg-6">
        <div class="card h-100 d-flex flex-column">
            <div class="card-header d-flex align-items-center gap-2 px-4 py-3"
                 style="background:linear-gradient(135deg,var(--color-dark-slate-deep),var(--color-dark-slate))!important;border-radius:14px 14px 0 0!important;">
                <div class="stat-card-icon" style="width:34px;height:34px;border-radius:8px;background:rgba(133,204,170,0.2);">
                    <i data-lucide="sparkles" class="icon-md" style="color:var(--color-light-green);"></i>
                </div>
                <h5 class="card-title fw-bold mb-0 text-white" style="font-size:0.95rem;">
                    CES SEO Copilot
                </h5>
                <span class="ms-auto badge" style="background:rgba(133,204,170,0.18);color:var(--color-light-green);border-radius:6px;font-size:0.68rem;letter-spacing:0.05em;">BETA</span>
            </div>
            <div class="card-body d-flex flex-column px-4 pt-4">

                <!-- Chat history area -->
                <div class="flex-grow-1 p-3 mb-3 rounded-3 overflow-auto"
                     style="min-height:180px;background:#f8fafc;border:1px solid rgba(47,79,79,0.08);">
                    <div class="d-flex mb-3">
                        <div class="chat-bubble">
                            <strong style="color:var(--color-dark-slate);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;">Copilot</strong><br>
                            Welcome to the SEO Copilot. How can I assist you with your content today?
                        </div>
                    </div>
                </div>

                <!-- Input area -->
                <div class="input-group mt-auto">
                    <input type="text" class="form-control"
                           placeholder="Ask Copilot a question..."
                           aria-label="Ask the SEO Copilot a question"
                           id="copilotInput"
                           style="border-right:none;border-radius:9px 0 0 9px;">
                    <button class="btn d-flex align-items-center gap-2 px-3"
                            id="copilotSendBtn"
                            type="button"
                            style="background:var(--color-dark-slate);color:#fff;border-radius:0 9px 9px 0;">
                        <i data-lucide="send" class="icon-sm"></i>
                        <span class="d-none d-sm-inline" style="font-size:0.85rem;">Send</span>
                    </button>
                </div>

            </div>
        </div>
    </div>

</div>
