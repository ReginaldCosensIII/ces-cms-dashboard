@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard Home";
}

<!-- Page Header -->
<div class="page-header">
    <h1 class="mb-0">Dashboard</h1>
    <p class="page-subtitle mb-0">Welcome back. Here's an overview of your system.</p>
</div>

<!-- Stat Cards Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon icon-green">
                <i data-lucide="database" class="icon-lg" style="color:var(--color-dark-slate);"></i>
            </div>
            <div class="stat-card-body">
                <div class="stat-value">Active</div>
                <div class="stat-label">Database</div>
                <div class="stat-sub text-success fw-medium">Connected</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon icon-slate">
                <i data-lucide="message-square-more" class="icon-lg" style="color:var(--color-dark-slate);"></i>
            </div>
            <div class="stat-card-body">
                <div class="stat-value">12</div>
                <div class="stat-label">Total FAQs</div>
                <div class="stat-sub">Published entries</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon icon-amber">
                <i data-lucide="clock" class="icon-lg" style="color:#d97706;"></i>
            </div>
            <div class="stat-card-body">
                <div class="stat-value">3</div>
                <div class="stat-label">Pending Reviews</div>
                <div class="stat-sub" style="color:#d97706;">Awaiting action</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon icon-maroon">
                <i data-lucide="cpu" class="icon-lg" style="color:var(--color-maroon);"></i>
            </div>
            <div class="stat-card-body">
                <div class="stat-value">Normal</div>
                <div class="stat-label">System Load</div>
                <div class="stat-sub">All services healthy</div>
            </div>
        </div>
    </div>
</div>

<!-- Detail Cards Row -->
<div class="row g-4">

    <!-- Left: System Status -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2 px-4 py-3">
                <div class="stat-card-icon icon-slate" style="width:34px;height:34px;border-radius:8px;">
                    <i data-lucide="activity" class="icon-md" style="color:var(--color-dark-slate);"></i>
                </div>
                <h5 class="card-title fw-bold mb-0" style="font-size:0.95rem;color:var(--color-dark-slate-deep);">
                    System Status
                </h5>
            </div>
            <div class="card-body px-4">
                <ul class="list-unstyled mb-0">

                    <li class="d-flex justify-content-between align-items-center py-3">
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="database" class="icon-sm" style="color:#6b7280;"></i>
                            <span class="fw-medium" style="font-size:0.9rem;">Database Connection</span>
                        </div>
                        <span class="badge px-3 py-2" style="background:rgba(34,197,94,0.1);color:#16a34a;border-radius:6px;font-size:0.75rem;">Active</span>
                    </li>
                    <hr class="gradient-divider my-0">

                    <li class="d-flex justify-content-between align-items-center py-3">
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="message-square-more" class="icon-sm" style="color:#6b7280;"></i>
                            <span class="fw-medium" style="font-size:0.9rem;">Total FAQs</span>
                        </div>
                        <span class="fw-bold fs-5" style="color:var(--color-dark-slate-deep);">12</span>
                    </li>
                    <hr class="gradient-divider my-0">

                    <li class="d-flex justify-content-between align-items-center py-3">
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="clock" class="icon-sm" style="color:#6b7280;"></i>
                            <span class="fw-medium" style="font-size:0.9rem;">Pending Reviews</span>
                        </div>
                        <span class="badge px-3 py-2" style="background:rgba(245,158,11,0.12);color:#d97706;border-radius:6px;font-size:0.75rem;">3 Pending</span>
                    </li>
                    <hr class="gradient-divider my-0">

                    <li class="d-flex justify-content-between align-items-center py-3">
                        <div class="d-flex align-items-center gap-2">
                            <i data-lucide="cpu" class="icon-sm" style="color:#6b7280;"></i>
                            <span class="fw-medium" style="font-size:0.9rem;">System Load</span>
                        </div>
                        <span class="fw-semibold" style="color:#16a34a;font-size:0.9rem;">Normal</span>
                    </li>

                </ul>
            </div>
        </div>
    </div>

    <!-- Right: CES SEO Copilot -->
    <div class="col-lg-6">
        <div class="card h-100 d-flex flex-column">
            <div class="card-header d-flex align-items-center gap-2 px-4 py-3"
                 style="background:linear-gradient(135deg,var(--color-dark-slate-deep),var(--color-dark-slate))!important;border-radius:14px 14px 0 0!important;">
                <div class="stat-card-icon" style="width:34px;height:34px;border-radius:8px;background:rgba(133,204,170,0.2);">
                    <i data-lucide="sparkles" class="icon-md" style="color:var(--color-light-green);"></i>
                </div>
                <h5 class="card-title fw-bold mb-0 text-white" style="font-size:0.95rem;">
                    CES SEO Copilot
                </h5>
                <span class="ms-auto badge" style="background:rgba(133,204,170,0.18);color:var(--color-light-green);border-radius:6px;font-size:0.68rem;letter-spacing:0.05em;">BETA</span>
            </div>
            <div class="card-body d-flex flex-column px-4 pt-4">

                <!-- Chat history area -->
                <div class="flex-grow-1 p-3 mb-3 rounded-3 overflow-auto"
                     style="min-height:180px;background:#f8fafc;border:1px solid rgba(47,79,79,0.08);">
                    <div class="d-flex mb-3">
                        <div class="chat-bubble">
                            <strong style="color:var(--color-dark-slate);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;">Copilot</strong><br>
                            Welcome to the SEO Copilot. How can I assist you with your content today?
                        </div>
                    </div>
                </div>

                <!-- Input area -->
                <div class="input-group mt-auto">
                    <input type="text" class="form-control"
                           placeholder="Ask Copilot a question..."
                           aria-label="Ask the SEO Copilot a question"
                           id="copilotInput"
                           style="border-right:none;border-radius:9px 0 0 9px;">
                    <button class="btn d-flex align-items-center gap-2 px-3"
                            id="copilotSendBtn"
                            type="button"
                            style="background:var(--color-dark-slate);color:#fff;border-radius:0 9px 9px 0;">
                        <i data-lucide="send" class="icon-sm"></i>
                        <span class="d-none d-sm-inline" style="font-size:0.85rem;">Send</span>
                    </button>
                </div>

            </div>
        </div>
    </div>

</div>
