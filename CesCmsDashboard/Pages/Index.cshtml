@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard Home";
}


<!-- Page Header -->
<div class="page-header">
    <h1 class="mb-0">Dashboard</h1>
    <p class="page-subtitle mb-0">Welcome back. Here's an overview of your system.</p>
</div>

<!-- Stat Cards Row -->
<div class="row g-3 mb-4 position-relative z-3">

    <!-- Total Content -->
    <div class="col-sm-6 col-xl-4">
        <div class="stat-card">
            <div class="stat-card-icon icon-green">
                <i data-lucide="files" class="icon-lg" style="color:#1a6644;"></i>
            </div>
            <div class="stat-card-body">
                <div class="stat-value">@Model.TotalFaqs</div>
                <div class="stat-label">Total FAQs</div>
                <div class="stat-sub">Frequently Asked Questions</div>
            </div>
        </div>
    </div>

    <!-- Published -->
    <div class="col-sm-6 col-xl-4">
        <div class="stat-card">
            <div class="stat-card-icon icon-green">
                <i data-lucide="circle-check-big" class="icon-lg" style="color:#1a6644;"></i>
            </div>
            <div class="stat-card-body">
                <div class="stat-value">@Model.TotalTechTips</div>
                <div class="stat-label">Total Tech Tips</div>
                <div class="stat-sub text-success fw-medium">Technical Guides</div>
            </div>
        </div>
    </div>

    <!-- System Status -->
    <div class="col-sm-12 col-xl-4">
        <div class="stat-card position-relative">
            @if (Model.IsDatabaseConnected)
            {
                <div class="stat-card-icon icon-green">
                    <i data-lucide="activity" class="icon-lg" style="color:#1a6644;"></i>
                </div>
                <div class="stat-card-body">
                    <div class="stat-value text-dark">Online</div>
                    <div class="stat-label">System Status</div>
                    <div class="stat-sub fw-medium" style="color:#1a6644;">Online & Connected</div>
                </div>
            }
            else
            {
                <div class="stat-card-icon" style="background-color:rgba(255, 0, 0, 0.1);">
                    <i data-lucide="activity" class="icon-lg" style="color:red;"></i>
                </div>
                <div class="stat-card-body">
                    <div class="stat-value" style="color:red;">Offline</div>
                    <div class="stat-label">System Status</div>
                    <div class="stat-sub text-danger fw-medium">Database Error</div>
                </div>
            }
            @* TODO: Re-evaluate for Production Sprint 2
            <div class="dropdown position-absolute bottom-0 end-0 m-2">
                <a href="#" class="text-muted text-decoration-none px-2" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 1.2rem;">
                    <i class="bi bi-plus-circle"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-3" style="min-width: 200px; font-size: 0.85rem; z-index: 1050;">
                    <li class="d-flex justify-content-between mb-2 text-muted"><strong>Database:</strong> <span class="ms-3 @(Model.IsDatabaseConnected ? "text-success" : "text-danger")">@(Model.IsDatabaseConnected ? "Connected" : "Error")</span></li>
                    <li class="d-flex justify-content-between mb-2 text-muted"><strong>Web Ping:</strong> <span class="ms-3 @(Model.IsWebsiteOnline ? "text-success" : "text-danger")">@(Model.IsWebsiteOnline ? "Online" : "Offline")</span></li>
                    <li class="d-flex justify-content-between text-muted"><strong>API Ping:</strong> <span class="ms-3 @(Model.IsApiOnline ? "text-success" : "text-danger")">@(Model.IsApiOnline ? "Online" : "Offline")</span></li>
                </ul>
            </div>
            *@
        </div>
    </div>

</div>

<!-- Detail Cards Row -->
<div class="row mb-4">

    <!-- Left: Recent Activity (Database-wired) -->
    <div class="col-lg-10 ms-0" style="max-width: 600px;">
        <div class="card dashboard-split-card">
            <div class="card-header d-flex align-items-center gap-2 px-4 py-3">
                <div class="stat-card-icon" style="width:34px;height:34px;border-radius:8px;background:rgba(133,204,170,0.2);">
                    <i data-lucide="list-checks" class="icon-md" style="color:#1a6644;"></i>
                </div>
                <h5 class="card-title fw-bold mb-0 activity-card-title">Recent Activity</h5>
            </div>
            <div class="card-body px-4 py-2">

                @if (!Model.RecentActivities.Any())
                {
                    <div class="d-flex align-items-center justify-content-center py-5 text-muted">
                        <i data-lucide="inbox" class="me-2 icon-md"></i>
                        <span style="font-size:0.875rem;">No recent activity yet.</span>
                    </div>
                }
                else
                {
                    <ul id="recent-activity-feed" class="list-unstyled mb-0 activity-list">
                        @foreach (var activity in Model.RecentActivities)
                        {
                            <!-- Determine icon + color class by content type -->
                            var iconName  = activity.Type == "FAQ" ? "message-square-more" : "lightbulb";
                            var iconClass = activity.Type == "FAQ" ? "activity-icon-edit"  : "activity-icon-plus";
                            var typeLabel = activity.Type;
                            var actionType = activity.Status; // Status holds ActionType (Created, Edited, Deleted)
                            var badgeColor = actionType == "Created" ? "success" : (actionType == "Deleted" ? "danger" : "primary");
                            var dateLabel = activity.Date.ToString("MMM dd, yyyy h:mm tt UTC");

                            <li class="activity-item">
                                <div class="activity-icon-wrap @iconClass" style="background:rgba(133, 204, 170, 0.2);">
                                    <i data-lucide="@iconName" class="icon-sm" style="color:#1a6644;"></i>
                                </div>
                                <div class="activity-text">
                                    <span class="activity-action" title="@activity.Title">
                                        @activity.Title 
                                        <span class="badge bg-@badgeColor ms-2">@actionType</span>
                                    </span>
                                    <span class="activity-time">
                                        <span class="badge rounded-pill px-2 py-1 me-1"
                                              style="font-size:0.65rem;background:rgba(133, 204, 170, 0.2);color:#1a6644;">
                                            @typeLabel
                                        </span>
                                        @dateLabel
                                    </span>
                                </div>
                            </li>
                        }
                    </ul>
                }

            </div>
        </div>
    </div>

