@page
@model CesCmsDashboard.Pages.Faqs.EditModel
@{
    ViewData["Title"] = "Edit FAQ";
}

<h1>Edit FAQ</h1>
<hr />
<div class="row">
    <div class="col-md-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Faq.Id" />
            
            <div class="form-group mb-3">
                <label asp-for="Faq.Question" class="control-label"></label>
                <input asp-for="Faq.Question" class="form-control" />
                <span asp-validation-for="Faq.Question" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Faq.Answer" class="control-label"></label>
                <textarea asp-for="Faq.Answer" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Faq.Answer" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Faq.DisplayOrder" class="control-label"></label>
                <input asp-for="Faq.DisplayOrder" class="form-control" />
                <span asp-validation-for="Faq.DisplayOrder" class="text-danger"></span>
            </div>
            <div class="form-group form-check mb-3">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Faq.IsPublished" /> @Html.DisplayNameFor(model => model.Faq.IsPublished)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
