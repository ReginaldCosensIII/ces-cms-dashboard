@page
@model CesCmsDashboard.Pages.Faqs.IndexModel
@{
    ViewData["Title"] = "FAQs";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="mb-0 fw-bold text-semantic-sidebar">FAQs Management</h2>
    <button class="btn btn-primary d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#faqModal">
        <i data-lucide="plus-circle" class="icon-sm"></i> Create New
    </button>
</div>

<div class="card border-0 shadow-sm mb-5">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Faq[0].Question)</th>
                        <th>@Html.DisplayNameFor(model => model.Faq[0].DisplayOrder)</th>
                        <th>@Html.DisplayNameFor(model => model.Faq[0].IsPublished)</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
            @foreach (var item in Model.Faq) {
                    <tr>
                        <td class="ps-4 fw-medium text-truncate max-w-300">@Html.DisplayFor(modelItem => item.Question)</td>
                        <td>@Html.DisplayFor(modelItem => item.DisplayOrder)</td>
                        <td>
                            @if (item.IsPublished)
                            {
                                <span class="badge bg-success rounded-pill px-3">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill px-3">Draft</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#faqModal">
                                <i data-lucide="edit-3" class="icon-sm"></i> Edit
                            </button>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-1 ms-1">
                                <i data-lucide="trash-2" class="icon-sm"></i> Delete
                            </a>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- FAQ Modal -->
<div class="modal fade" id="faqModal" tabindex="-1" aria-labelledby="faqModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-semantic-navbar border-bottom-0 text-white">
        <h5 class="modal-title fw-bold text-white" id="faqModalLabel">Create / Edit FAQ</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
         <form>
            <div class="mb-4">
               <label class="form-label fw-bold text-muted small text-uppercase">Question</label>
               <input type="text" class="form-control form-control-lg fs-6" placeholder="Enter the FAQ question here..." />
            </div>
            <div class="mb-4">
               <label class="form-label fw-bold text-muted small text-uppercase">Answer</label>
               <textarea class="form-control wysiwyg-placeholder" rows="6" placeholder="Provide the detailed answer..."></textarea>
            </div>
            <div class="row g-4">
               <div class="col-sm-6">
                   <label class="form-label fw-bold text-muted small text-uppercase">Display Order</label>
                   <input type="number" class="form-control" value="0" />
               </div>
               <div class="col-sm-6 d-flex align-items-end pb-1">
                   <div class="form-check form-switch fs-5">
                       <input class="form-check-input" type="checkbox" role="switch" id="isPublishedSwitch" checked>
                       <label class="form-check-label fs-6 ms-2" for="isPublishedSwitch">Pubished to site</label>
                   </div>
               </div>
            </div>
         </form>
      </div>
      <div class="modal-footer border-top-0 pt-0 pb-4 px-4 bg-transparent d-flex justify-content-between">
        <button type="button" class="btn btn-light border fw-medium" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary d-flex align-items-center gap-2 fw-medium px-4">
            <i data-lucide="save" class="icon-sm"></i> Save Changes
        </button>
      </div>
    </div>
  </div>
</div>
