@page
@model CesCmsDashboard.Pages.Faqs.IndexModel
@{
    ViewData["Title"] = "FAQs";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="mb-0 fw-bold text-semantic-sidebar">FAQs Management</h2>
    <button class="btn btn-primary d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#createFaqModal">
        <i data-lucide="plus-circle" class="icon-sm"></i> Create New
    </button>
</div>

<div class="card border-0 shadow-sm mb-5">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Faq[0].Question)</th>
                        <th>@Html.DisplayNameFor(model => model.Faq[0].DisplayOrder)</th>
                        <th>@Html.DisplayNameFor(model => model.Faq[0].IsPublished)</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
            @foreach (var item in Model.Faq) {
                    <tr>
                        <td class="ps-4 fw-medium text-truncate max-w-300">@Html.DisplayFor(modelItem => item.Question)</td>
                        <td>@Html.DisplayFor(modelItem => item.DisplayOrder)</td>
                        <td>
                            @if (item.IsPublished)
                            {
                                <span class="badge bg-success rounded-pill px-3">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill px-3">Draft</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#editFaqModal"
                                    data-id="@item.Id" data-question="@item.Question" data-answer="@item.Answer" data-displayorder="@item.DisplayOrder" data-ispublished="@(item.IsPublished ? "true" : "false")">
                                <i data-lucide="edit-3" class="icon-sm"></i> Edit
                            </button>
                            <button class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-1 ms-1" data-bs-toggle="modal" data-bs-target="#deleteFaqModal" data-id="@item.Id">
                                <i data-lucide="trash-2" class="icon-sm"></i> Delete
                            </button>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create FAQ Modal -->
<div class="modal fade" id="createFaqModal" tabindex="-1" aria-labelledby="createFaqModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <form method="post" asp-page-handler="Create">
        <div class="modal-header bg-semantic-navbar border-bottom-0 text-white">
          <h5 class="modal-title fw-bold text-white" id="createFaqModalLabel">Create FAQ</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-4">
           <div class="mb-4">
              <label class="form-label fw-bold text-muted small text-uppercase">Question</label>
              <input type="text" name="newFaq.Question" class="form-control form-control-lg fs-6" placeholder="Enter the FAQ question here..." />
           </div>
           <div class="mb-4">
              <label class="form-label fw-bold text-muted small text-uppercase">Answer</label>
              <div id="create-quill-editor" class="quill-editor-container" style="height: 200px;"></div>
              <input type="hidden" id="CreateAnswer" name="newFaq.Answer" />
           </div>
           <div class="row g-4">
              <div class="col-sm-6">
                  <label class="form-label fw-bold text-muted small text-uppercase">Display Order</label>
                  <input type="number" name="newFaq.DisplayOrder" class="form-control" value="0" />
              </div>
              <div class="col-sm-6 d-flex align-items-end pb-1">
                  <div class="form-check form-switch fs-5">
                      <input class="form-check-input" type="checkbox" role="switch" id="isPublishedSwitchCreate" name="newFaq.IsPublished" value="true" checked>
                      <label class="form-check-label fs-6 ms-2" for="isPublishedSwitchCreate">Pubished to site</label>
                  </div>
              </div>
           </div>
        </div>
        <div class="modal-footer border-top-0 pt-0 pb-4 px-4 bg-transparent d-flex justify-content-between">
          <button type="button" class="btn btn-light border fw-medium" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary d-flex align-items-center gap-2 fw-medium px-4">
              <i data-lucide="save" class="icon-sm"></i> Save Changes
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit FAQ Modal -->
<div class="modal fade" id="editFaqModal" tabindex="-1" aria-labelledby="editFaqModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <form method="post" asp-page-handler="Edit">
        <input type="hidden" name="updatedFaq.Id" />
        <div class="modal-header bg-semantic-navbar border-bottom-0 text-white">
          <h5 class="modal-title fw-bold text-white" id="editFaqModalLabel">Edit FAQ</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-4">
           <div class="mb-4">
              <label class="form-label fw-bold text-muted small text-uppercase">Question</label>
              <input type="text" name="updatedFaq.Question" class="form-control form-control-lg fs-6" placeholder="Enter the FAQ question here..." />
           </div>
           <div class="mb-4">
              <label class="form-label fw-bold text-muted small text-uppercase">Answer</label>
              <div id="edit-quill-editor" class="quill-editor-container" style="height: 200px;"></div>
              <input type="hidden" id="EditAnswer" name="updatedFaq.Answer" />
           </div>
           <div class="row g-4">
              <div class="col-sm-6">
                  <label class="form-label fw-bold text-muted small text-uppercase">Display Order</label>
                  <input type="number" name="updatedFaq.DisplayOrder" class="form-control" value="0" />
              </div>
              <div class="col-sm-6 d-flex align-items-end pb-1">
                  <div class="form-check form-switch fs-5">
                      <input class="form-check-input" type="checkbox" role="switch" id="isPublishedSwitchEdit" name="updatedFaq.IsPublished" value="true">
                      <label class="form-check-label fs-6 ms-2" for="isPublishedSwitchEdit">Pubished to site</label>
                  </div>
              </div>
           </div>
        </div>
        <div class="modal-footer border-top-0 pt-0 pb-4 px-4 bg-transparent d-flex justify-content-between">
          <button type="button" class="btn btn-light border fw-medium" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary d-flex align-items-center gap-2 fw-medium px-4">
              <i data-lucide="save" class="icon-sm"></i> Save Changes
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete FAQ Modal -->
<div class="modal fade" id="deleteFaqModal" tabindex="-1" aria-labelledby="deleteFaqModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <form method="post" asp-page-handler="Delete">
        <input type="hidden" name="id" />
        <div class="modal-header bg-danger border-bottom-0 text-white">
          <h5 class="modal-title fw-bold text-white" id="deleteFaqModalLabel">Delete FAQ</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-4 text-center">
           <i data-lucide="alert-triangle" class="text-danger mb-3" style="width: 48px; height: 48px;"></i>
           <p class="fs-5 mb-1 text-semantic-sidebar">Are you sure you want to delete this FAQ?</p>
           <p class="text-muted small">This action cannot be undone.</p>
        </div>
        <div class="modal-footer border-top-0 pt-0 pb-4 px-4 bg-transparent d-flex justify-content-between">
          <button type="button" class="btn btn-light border fw-medium" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger d-flex align-items-center gap-2 fw-medium px-4">
              <i data-lucide="trash-2" class="icon-sm text-white"></i> Delete FAQ
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
// ── Quill Tooltip Map ────────────────────────────────────────────────────────
const quillTooltips = {
    'ql-bold':        'Bold (Ctrl+B)',
    'ql-italic':      'Italic (Ctrl+I)',
    'ql-underline':   'Underline (Ctrl+U)',
    'ql-strike':      'Strikethrough',
    'ql-list':        'List',
    'ql-link':        'Insert Link',
    'ql-clean':       'Remove Formatting',
};

// Search the parent element for .ql-toolbar (works regardless of Quill v2 insertion point)
function applyQuillTooltips(editorContainerId) {
    const container = document.getElementById(editorContainerId);
    if (!container) return;
    const toolbar = container.parentElement.querySelector('.ql-toolbar');
    if (!toolbar) return;
    toolbar.querySelectorAll('button, .ql-picker-label').forEach(el => {
        for (const [cls, label] of Object.entries(quillTooltips)) {
            if (el.classList.contains(cls)) {
                el.setAttribute('title', label);
                el.setAttribute('aria-label', label);
                break;
            }
        }
    });
}

// Shared toolbar config
const TOOLBAR_CONFIG = [
    ['bold', 'italic', 'underline', 'strike'],
    [{ 'list': 'ordered' }, { 'list': 'bullet' }],
    ['link'],
    ['clean']
];

// ── Create Modal ─────────────────────────────────────────────────────────────
let createQuill = null;

document.getElementById('createFaqModal').addEventListener('shown.bs.modal', function () {
    if (createQuill) return; // guard: only init once per modal session
    createQuill = new Quill('#create-quill-editor', {
        theme: 'snow',
        placeholder: 'Write the FAQ answer here…',
        modules: { toolbar: TOOLBAR_CONFIG }
    });
    applyQuillTooltips('create-quill-editor');
    createQuill.on('text-change', () => {
        document.getElementById('CreateAnswer').value = createQuill.root.innerHTML;
    });
});

document.getElementById('createFaqModal').addEventListener('hidden.bs.modal', function () {
    if (!createQuill) return;
    createQuill.setText('');
    document.getElementById('CreateAnswer').value = '';
});

// ── Edit Modal ───────────────────────────────────────────────────────────────
let editQuill = null;

document.getElementById('editFaqModal').addEventListener('show.bs.modal', function (event) {
    const btn = event.relatedTarget;
    if (!btn) return;

    const form = this.querySelector('form');
    form.querySelector('[name="updatedFaq.Id"]').value            = btn.getAttribute('data-id');
    form.querySelector('[name="updatedFaq.Question"]').value      = btn.getAttribute('data-question');
    form.querySelector('[name="updatedFaq.DisplayOrder"]').value  = btn.getAttribute('data-displayorder');
    form.querySelector('[name="updatedFaq.IsPublished"]').checked = (btn.getAttribute('data-ispublished') === 'true');

    const answer = btn.getAttribute('data-answer') || '';

    if (!editQuill) {
        editQuill = new Quill('#edit-quill-editor', {
            theme: 'snow',
            placeholder: 'Write the FAQ answer here…',
            modules: { toolbar: TOOLBAR_CONFIG }
        });
        applyQuillTooltips('edit-quill-editor');
        editQuill.on('text-change', () => {
            document.getElementById('EditAnswer').value = editQuill.root.innerHTML;
        });
    }

    editQuill.root.innerHTML = answer;
    document.getElementById('EditAnswer').value = answer;
});

// ── Delete Modal ─────────────────────────────────────────────────────────────
document.getElementById('deleteFaqModal').addEventListener('show.bs.modal', function (event) {
    const btn = event.relatedTarget;
    if (!btn) return;
    this.querySelector('[name="id"]').value = btn.getAttribute('data-id');
});
</script>
}
