@page
@model CesCmsDashboard.Pages.Faqs.DeleteModel
@{
    ViewData["Title"] = "Delete FAQ";
}

<h1>Delete FAQ</h1>
<h3>Are you sure you want to delete this FAQ?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Faq.Question)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Faq.Question)</dd>
        
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Faq.Answer)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Faq.Answer)</dd>
        
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Faq.DisplayOrder)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Faq.DisplayOrder)</dd>
        
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Faq.IsPublished)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Faq.IsPublished)</dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Faq.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
