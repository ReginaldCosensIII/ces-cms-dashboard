<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="CES CMS Dashboard — Content Management System for CES IT Services" />
    <title>@ViewData["Title"] — CES CMS Dashboard</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CesCmsDashboard.styles.css" asp-append-version="true" />
</head>
<body>

    <partial name="_Navbar" />

    <div class="d-flex" style="overflow:hidden;">
        <partial name="_Sidebar" />
        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();

            const toggleBtn     = document.getElementById('sidebarToggle');
            const toggleWrapper = document.getElementById('sidebarToggleWrapper');
            const toggleIcon    = document.getElementById('sidebarToggleIcon');
            const sidebar       = document.getElementById('sidebarMenu');

            if (toggleBtn && sidebar && toggleIcon && toggleWrapper) {
                toggleBtn.addEventListener('click', () => {
                    const isCollapsed = sidebar.classList.toggle('sidebar-collapsed');
                    toggleIcon.setAttribute('data-lucide', isCollapsed ? 'panel-left-open' : 'panel-left-close');
                    lucide.createIcons();
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
